{
  "name": "pulsecheck",
  "version": "1.0.0",
  "description": "PulseCheck uptime monitoring service built with Express, PostgreSQL, Prisma, node-cron, and Axios.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/server.js",
    "dev:api": "node --watch src/server.js",
    "dev:client": "vite --config client/vite.config.mjs --host 0.0.0.0",
    "build": "npm run build:client",
    "build:client": "vite build --config client/vite.config.mjs",
    "preview:client": "vite preview --config client/vite.config.mjs --host 0.0.0.0",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "uptime",
    "monitoring",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "lucide-react": "^1.14.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.11"
  },
  "engines": {
    "node": ">=18.18"
  }
}
